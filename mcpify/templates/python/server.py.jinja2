@app.call_tool()
async def _handle_{{ tool.name }}(name: str, arguments: dict) -> list[types.TextContent]:
    if name != "{{ tool.name }}":
        raise ValueError(f"Unknown tool: {name}")
    
    # Build URL
    url = BASE_URL + "{{ tool.path }}"
    {% for param in tool.params %}{% if param.location == "path" %}
    if "{{ param.name }}" in arguments:
        url = url.replace("{ {{ '{' }}{{ param.name }}{{ '}' }} }", str(arguments["{{ param.name }}"]))
    {% endif %}{% endfor %}
    
    # Query parameters
    query_params = {}
    {% for param in tool.params %}{% if param.location == "query" %}
    if "{{ param.name }}" in arguments and arguments["{{ param.name }}"] is not None:
        query_params["{{ param.name }}"] = arguments["{{ param.name }}"]
    {% endif %}{% endfor %}
    
    # Request body
    body = {}
    {% for param in tool.params %}{% if param.location == "body" %}
    if "{{ param.name }}" in arguments and arguments["{{ param.name }}"] is not None:
        body["{{ param.name }}"] = arguments["{{ param.name }}"]
    {% endif %}{% endfor %}
    
    async with httpx.AsyncClient(timeout=30.0) as client:
        response = await client.{{ tool.method | lower }}(
            url,
            params=query_params if query_params else None,
            json=body if body else None,
            headers=_build_headers(),
        )
        
        # Return raw response text — Claude will interpret it
        try:
            response.raise_for_status()
        except httpx.HTTPStatusError as e:
            return [types.TextContent(
                type="text",
                text=f"HTTP Error {e.response.status_code}: {e.response.text}"
            )]
        
        return [types.TextContent(type="text", text=response.text)]

{% endfor %}

@app.list_tools()
async def list_tools() -> list[types.Tool]:
    """Return all available tools to Claude."""
    return [
        {% for tool in spec.tools %}
        types.Tool(
            name="{{ tool.name }}",
            description="{{ tool.description | replace('"', '\\"') }}",
            inputSchema={
                "type": "object",
                "properties": {
                    {% for param in tool.params %}
                    "{{ param.name }}": {
                        "type": "{{ param.type }}",
                        {% if param.description %}"description": "{{ param.description | replace('"', '\\"') }}",{% endif %}
                        {% if param.enum %}"enum": {{ param.enum | tojson }},{% endif %}
                    },
                    {% endfor %}
                },
                "required": [{% for param in tool.params %}{% if param.required %}"{{ param.name }}", {% endif %}{% endfor %}],
            },
        ),
        {% endfor %}
    ]


